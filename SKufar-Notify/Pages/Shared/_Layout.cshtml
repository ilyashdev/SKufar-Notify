<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — Skufar</title>
    <link rel="icon" type="image/png" href="~/ico.png"/>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/SKufar-Notify.styles.css" asp-append-version="true"/>
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
<header>
    <nav class="navbar navbar-expand-sm navbar-light">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">skufar</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1 gap-1">
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Index" ? "active" : "")" asp-page="/Index">Мои фильтры</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "KufarFilter" ? "active" : "")" asp-page="/KufarFilter">Новый фильтр</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Settings" ? "active" : "")" asp-page="/Settings">Настройки</a>
                    </li>
                </ul>
                <form method="post" asp-page="/Logout" class="d-flex align-items-center gap-2">
                    @Html.AntiForgeryToken()
                    <small class="text-muted">@User.Identity.Name</small>
                    <button type="submit" class="btn btn-sm btn-skufar-outline">Выйти</button>
                </form>
            </div>
        </div>
    </nav>
</header>
}

<div class="container py-4">
    <main role="main">
        @RenderBody()
    </main>
</div>

@if (User.Identity?.IsAuthenticated == true)
{
<footer class="border-top footer py-3">
    <div class="container">
        <small class="text-muted">© @DateTime.Now.Year Skufar</small>
    </div>
</footer>
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
