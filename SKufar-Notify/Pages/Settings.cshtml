@page
@model SettingsModel
@{
    ViewData["Title"] = "Настройки";
    ViewData["ActivePage"] = "Settings";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2>Настройки</h2>
</div>

@if (Model.Saved)
{
    <div class="alert alert-success rounded-3 mb-4">Настройки сохранены.</div>
}

<form method="post">
    @Html.AntiForgeryToken()

    <div class="form-section">
        <div class="form-section-title">Авторизация</div>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Логин</label>
                <input type="text" class="form-control" asp-for="Username" autocomplete="off">
            </div>
            <div class="col-md-6">
                <label class="form-label">Новый пароль <small class="text-muted fw-normal">(оставьте пустым, чтобы не менять)</small></label>
                <input type="password" class="form-control" asp-for="Password" autocomplete="new-password" placeholder="••••••••">
            </div>
        </div>
    </div>

    <div class="form-section">
        <div class="form-section-title">Telegram</div>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Bot API Token</label>
                <input type="text" class="form-control font-monospace" asp-for="TelegramBotToken"
                       placeholder="123456789:AAF...">
                <div class="form-text">Получить у <a href="https://t.me/BotFather" target="_blank">@@BotFather</a></div>
            </div>
            <div class="col-md-6">
                <label class="form-label">Chat ID</label>
                <input type="text" class="form-control font-monospace" asp-for="TelegramChatId"
                       placeholder="-100123456789">
                <div class="form-text">ID чата или пользователя для уведомлений</div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-2">
        <button type="submit" class="btn btn-skufar px-4">Сохранить</button>
        <a asp-page="/Index" class="btn btn-skufar-outline px-4">Назад</a>
    </div>
</form>
