@page
@model SkufarFilterModel
@{
    ViewData["Title"] = Model.IsEdit ? "Изменить фильтр" : "Новый фильтр";
    ViewData["ActivePage"] = "KufarFilter";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2>@(Model.IsEdit ? "Изменить фильтр" : "Новый фильтр")</h2>
    <a asp-page="/Index" class="btn btn-skufar-outline">← К списку</a>
</div>

<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="FilterId">

    @* Название *@
    <div class="form-section">
        <div class="form-section-title">Название фильтра</div>
        <input type="text" class="form-control form-control-lg fw-semibold"
               asp-for="FilterName" placeholder=""
               style="font-size:1.1rem">
    </div>

    @* Поиск *@
    <div class="form-section">
        <div class="form-section-title">Поисковый запрос</div>
        <div class="row g-3 align-items-end">
            <div class="col-md-9">
                <label class="form-label">Ключевые слова</label>
                <input type="text" class="form-control" asp-for="Tag">
            </div>
            <div class="col-md-3">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" asp-for="OnlyTitleSearch" id="ot">
                    <label class="form-check-label fw-semibold" for="ot">Только в заголовке</label>
                </div>
            </div>
        </div>
    </div>

    @* Категория *@
    <div class="form-section">
        <div class="form-section-title">Категория</div>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Категория</label>
                <select class="form-select" asp-for="Category" id="categorySelect" onchange="updateSubcategories()">
                    <option value="">Все категории</option>
                    <option value="1000">Недвижимость</option>
                    <option value="2000">Автомобили и транспорт</option>
                    <option value="15000">Бытовая техника</option>
                    <option value="16000">Компьютерная техника</option>
                    <option value="17000">Телефоны и планшеты</option>
                    <option value="5000">Электроника</option>
                    <option value="8000">Женский гардероб</option>
                    <option value="19000">Мужской гардероб</option>
                    <option value="18000">Красота и здоровье</option>
                    <option value="12000">Всё для детей и мам</option>
                    <option value="21000">Мебель</option>
                    <option value="3000">Всё для дома</option>
                    <option value="14000">Ремонт и стройка</option>
                    <option value="10000">Сад и огород</option>
                    <option value="4000">Хобби, спорт и туризм</option>
                    <option value="9000">Свадьба и праздники</option>
                    <option value="11000">Животные</option>
                    <option value="20000">Готовый бизнес и оборудование</option>
                    <option value="6000">Работа</option>
                    <option value="13000">Услуги</option>
                    <option value="7000">Прочее</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Подкатегория</label>
                <select class="form-select" asp-for="SubCategory" id="subcategorySelect">
                    <option value="">Все подкатегории</option>
                </select>
            </div>
        </div>
    </div>

    @* Цена и параметры *@
    <div class="form-section">
        <div class="form-section-title">Цена и параметры</div>
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Цена от (BYN)</label>
                <input type="number" class="form-control" asp-for="PriceMin" placeholder="0" min="0">
            </div>
            <div class="col-md-3">
                <label class="form-label">Цена до (BYN)</label>
                <input type="number" class="form-control" asp-for="PriceMax" placeholder="∞" min="0">
            </div>
            <div class="col-md-3">
                <label class="form-label">Валюта</label>
                <select class="form-select" asp-for="Currency">
                    <option value="">Любая</option>
                    <option value="BYR">BYN</option>
                    <option value="USD">USD</option>
                    <option value="EUR">EUR</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Состояние</label>
                <select class="form-select" asp-for="Condition">
                    <option value="">Любое</option>
                    <option value="2">Новое</option>
                    <option value="1">Б/У</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Тип продавца</label>
                <select class="form-select" asp-for="SellerType">
                    <option value="">Любой</option>
                    <option value="0">Частное лицо</option>
                    <option value="1">Компания</option>
                </select>
            </div>
        </div>
    </div>

    @* Регион *@
    <div class="form-section">
        <div class="form-section-title">Регион</div>
        <div class="row g-3">
            <div class="col-md-5">
                <label class="form-label">Регион</label>
                <select class="form-select" asp-for="Region" id="regionSelect" onchange="updateAreas()">
                    <option value="">Вся Беларусь</option>
                    <option value="7">Минск</option>
                    <option value="1">Брестская область</option>
                    <option value="2">Гомельская область</option>
                    <option value="3">Гродненская область</option>
                    <option value="4">Могилёвская область</option>
                    <option value="5">Минская область</option>
                    <option value="6">Витебская область</option>
                </select>
            </div>
            <div class="col-md-7" id="areasBlock" style="display:none">
                <label class="form-label">Города / Районы <small class="text-muted fw-normal normal-case">(Ctrl+клик — несколько)</small></label>
                <select class="form-select" asp-for="Areas" id="areasSelect" multiple size="5"></select>
            </div>
        </div>
    </div>

    @* Дополнительно *@
    <div class="form-section">
        <div class="form-section-title">Дополнительные фильтры</div>
        <div class="d-flex flex-wrap gap-4">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" asp-for="OnlyWithPhotos" id="oph">
                <label class="form-check-label" for="oph">Только с фото</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" asp-for="OnlyWithVideos" id="ovi">
                <label class="form-check-label" for="ovi">Только с видео</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" asp-for="OnlyWithExchange" id="pse">
                <label class="form-check-label" for="pse">Возможен обмен</label>
            </div>
        </div>
    </div>

    @* Actions *@
    <div class="d-flex gap-2 mb-4">
        <button type="submit" asp-page-handler="Save" class="btn btn-skufar px-5">Сохранить</button>
        <a asp-page="/Index" class="btn btn-skufar-outline px-4">Отмена</a>
    </div>
</form>

