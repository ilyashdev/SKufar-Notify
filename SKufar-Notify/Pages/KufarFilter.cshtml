function updateSubcategories() {
    const cat = parseInt(document.getElementById('categorySelect').value);
    const sel = document.getElementById('subcategorySelect');
    const prev = sel.value;
    sel.innerHTML = '<option value="">Все подкатегории</option>';
    (subcategories[cat] || []).forEach(([v, l]) => {
        const o = document.createElement('option');
        o.value = v; o.textContent = l;
        if (String(v) === prev) o.selected = true;
        sel.appendChild(o);
    });
}

function updateAreas() {
    const rgn = parseInt(document.getElementById('regionSelect').value);
    const block = document.getElementById('areasBlock');
    const sel = document.getElementById('areasSelect');
    sel.innerHTML = '';
    if (!rgn || !areas[rgn]) { block.style.display = 'none'; return; }
    areas[rgn].forEach(([v, l]) => {
        const o = document.createElement('option');
        o.value = v; o.textContent = l;
        sel.appendChild(o);
    });
    block.style.display = 'block';
}

// Restore dynamic dropdowns after GET/POST
(function () {
    const cat = '@(Model.Category?.ToString() ?? "")';
    const rgn = '@(Model.Region?.ToString() ?? "")';
    const sub = '@(Model.SubCategory?.ToString() ?? "")';

    if (cat) { document.getElementById('categorySelect').value = cat; updateSubcategories(); }
    if (sub) document.getElementById('subcategorySelect').value = sub;
    if (rgn) { document.getElementById('regionSelect').value = rgn; updateAreas(); }

    @if (Model.Areas is { Count: > 0 })
    {
        <text>
        const sel = [  @Html.Raw(string.Join(",", Model.Areas))  ];
        Array.from(document.getElementById('areasSelect').options)
             .forEach(o => { if (sel.includes(+o.value)) o.selected = true; });
        </text>
    }
})();
</script>
